<%- include('../layouts/main') %>

<!-- Hero -->
<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
  <div class="absolute inset-0 bg-bg-secondary">
    <div class="absolute inset-0" style="background-image: url('/images/vehicles/opt-10.jpg'); background-size: cover; background-position: center;"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/85 to-bg-primary/40"></div>
  </div>
  <div class="container-vmax relative z-10">
    <nav class="mb-8 text-sm text-text-muted" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text-secondary transition-colors">Start</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">B2B-Prüftechnik</span>
    </nav>
    <span class="label-caps text-burnt block mb-4">Für Hersteller, Importeure & Tuning-Anbieter</span>
    <h1 class="font-display text-4xl md:text-5xl lg:text-display-section uppercase tracking-tight leading-[1.05] max-w-4xl">
      B2B-Prüftechnik &amp; Daten
    </h1>
    <p class="mt-6 text-lg text-text-secondary max-w-2xl">
      Prüfstandsmessungen, Abgasdaten und aufbereitete Unterlagen für Ihre Sachverständigen-Partner. Bundesweit, NDA-fähig.
    </p>
  </div>
</section>

<!-- Editorial + Sidebar -->
<section class="section-spacing">
  <div class="container-vmax">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <div class="lg:col-span-7 order-2 lg:order-1">
        <div class="space-y-6 text-text-secondary text-lg leading-relaxed">
          <p>
            Hinter jedem Tuningartikel, der legal verkauft werden darf, steckt ein Gutachten. Hinter jedem Gutachten stecken Tests, Messungen und Dokumentation. Genau das ist unsere Stärke im B2B-Bereich.
          </p>
          <p>
            Ob Sie ein Tuninghersteller sind, der seine Produkte für den deutschen Markt zulassen möchte, ein Importeur, der Daten für Teilegutachten ausländischer Komponenten braucht, oder ein Kfz-Fachbetrieb, der Abgasmessungen für die Eintragung eines Kunden-Fahrzeugs benötigt — wir liefern die technische Grundlage.
          </p>
          <p>
            Unsere Prüfstandstechnik und unsere Erfahrung mit den Anforderungen der Prüforganisationen machen uns zu einem zuverlässigen Partner für Ihre Zulassungsprojekte.
          </p>
        </div>

        <h2 class="font-display text-2xl md:text-display-card uppercase tracking-tight text-text-primary mt-14 mb-6">
          Unsere B2B-Services
        </h2>

        <!-- Services -->
        <div class="space-y-6">
          <div class="border-l-2 border-burnt pl-6 py-2">
            <h3 class="font-display text-lg uppercase tracking-tight text-text-primary mb-2">Prüfstandsmessung &amp; Leistungstests</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Allrad-Leistungsmessung am MAHA-Prüfstand. PS, Drehmoment, Lambda und Druck über den kompletten Drehzahlbereich. Standardisierte Diagramme + Rohdaten als CSV. Vorher-Nachher-Vergleiche für Eintragungs-Dokumentationen.
            </p>
          </div>
          <div class="border-l-2 border-burnt pl-6 py-2">
            <h3 class="font-display text-lg uppercase tracking-tight text-text-primary mb-2">Abgasmessungen &amp; Emissions-Nachweise</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Abgasmessung vor und nach Modifikation. Nachweis der Einhaltung der geltenden Emissionsgrenzwerte — unverzichtbar für die Eintragung leistungsverändernder Maßnahmen. Wir messen Euro-5 und Euro-6 konform.
            </p>
          </div>
          <div class="border-l-2 border-burnt pl-6 py-2">
            <h3 class="font-display text-lg uppercase tracking-tight text-text-primary mb-2">Vorbereitung Teilegutachten</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Datenaufbereitung und Prüfstandsmessungen für Teilegutachten nach §&thinsp;19(3) und §&thinsp;22 StVZO. Die finale Gutachten-Erstellung erfolgt in Kooperation mit zugelassenen Sachverständigen unserer Partner-Prüforganisationen.
            </p>
          </div>
          <div class="border-l-2 border-burnt pl-6 py-2">
            <h3 class="font-display text-lg uppercase tracking-tight text-text-primary mb-2">Begleitung Tuningartikel-Zulassung</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Sie möchten ein Produkt auf den deutschen Markt bringen? Wir begleiten den Prozess auf Hersteller-Seite — Erstprüfung, Messdatenaufbereitung, Schnittstelle zur Prüforganisation. ABE / Teilegutachten werden durch akkreditierte Stellen erteilt.
            </p>
          </div>
        </div>

        <h2 class="font-display text-2xl md:text-display-card uppercase tracking-tight text-text-primary mt-14 mb-4">
          Für wen wir arbeiten
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
          <div class="flex items-center gap-3 p-4 border border-border-subtle bg-bg-tertiary">
            <svg class="w-5 h-5 text-burnt flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21"/></svg>
            <span class="text-text-primary text-sm font-medium">Tuninghersteller</span>
          </div>
          <div class="flex items-center gap-3 p-4 border border-border-subtle bg-bg-tertiary">
            <svg class="w-5 h-5 text-burnt flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            <span class="text-text-primary text-sm font-medium">Teile-Importeure</span>
          </div>
          <div class="flex items-center gap-3 p-4 border border-border-subtle bg-bg-tertiary">
            <svg class="w-5 h-5 text-burnt flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384 5.384a2.25 2.25 0 01-3.182-3.182L8.238 11.99M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/></svg>
            <span class="text-text-primary text-sm font-medium">Tuning-Anbieter</span>
          </div>
          <div class="flex items-center gap-3 p-4 border border-border-subtle bg-bg-tertiary">
            <svg class="w-5 h-5 text-burnt flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0020.25 9.35m-16.5 0L2.25 5.25h19.5L20.25 9.35"/></svg>
            <span class="text-text-primary text-sm font-medium">Autohäuser &amp; Händler</span>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-5 order-1 lg:order-2">
        <div class="lg:sticky lg:top-28 space-y-6">
          <div class="border border-border-subtle p-6 bg-bg-tertiary">
            <p class="label-caps text-burnt mb-4">B2B auf einen Blick</p>
            <dl class="space-y-4">
              <div class="flex justify-between items-baseline"><dt class="text-text-secondary text-sm">Prüfstandstechnik</dt><dd class="text-success text-sm font-medium">MAHA Allrad</dd></div>
              <div class="border-t border-border-subtle"></div>
              <div class="flex justify-between items-baseline"><dt class="text-text-secondary text-sm">Abgasmesstechnik</dt><dd class="text-success text-sm font-medium">Euro 5 &amp; 6</dd></div>
              <div class="border-t border-border-subtle"></div>
              <div class="flex justify-between items-baseline"><dt class="text-text-secondary text-sm">Vertraulichkeit</dt><dd class="text-success text-sm font-medium">NDA fähig</dd></div>
              <div class="border-t border-border-subtle"></div>
            </dl>
          </div>
          <div class="border border-border-subtle p-6 bg-bg-tertiary">
            <p class="font-display text-lg uppercase tracking-tight text-text-primary mb-2">Kontakt</p>
            <p class="text-text-secondary text-sm mb-6">Für B2B-Anfragen am besten per E-Mail mit Projektbeschreibung. Vertraulichkeit ist selbstverständlich.</p>
            <a href="mailto:<%= email %>?subject=B2B-Anfrage" class="btn-ghost w-full justify-center text-sm"><%= email %></a>
          </div>

          <!-- Trust-Box -->
          <div class="border border-border-subtle p-6 bg-bg-tertiary">
            <p class="label-caps text-text-muted mb-3">Warum Vmax Sued</p>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-text-secondary text-sm">
                <svg class="w-4 h-4 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Eigene Prüfstandstechnik vor Ort
              </li>
              <li class="flex items-start gap-2 text-text-secondary text-sm">
                <svg class="w-4 h-4 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Direkte Kontakte zu GTÜ, Dekra, TÜV Süd
              </li>
              <li class="flex items-start gap-2 text-text-secondary text-sm">
                <svg class="w-4 h-4 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Diskretion bei Produktentwicklungen
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section-spacing bg-bg-secondary">
  <div class="container-vmax max-w-3xl">
    <span class="label-caps text-burnt block mb-4">Häufige Fragen</span>
    <h2 class="font-display text-2xl md:text-display-card uppercase tracking-tight mb-10">B2B-Prüftechnik — FAQ</h2>

    <div class="space-y-4">
      <% faq.forEach(function(item) { %>
      <div class="border border-border-subtle bg-bg-tertiary">
        <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
          <span class="text-text-primary font-medium text-sm pr-4"><%= item.q %></span>
          <svg class="w-5 h-5 text-burnt flex-shrink-0 faq-icon transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5">
          <p class="text-text-secondary text-sm leading-relaxed"><%= item.a %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Related Links -->
<section class="py-16 border-t border-border-subtle">
  <div class="container-vmax">
    <p class="text-text-muted text-sm">Auch für Endkunden</p>
    <div class="flex flex-wrap gap-x-6 gap-y-2 mt-2">
      <a href="/chiptuning" class="text-text-secondary hover:text-burnt transition-colors text-sm">Chiptuning &rarr;</a>
      <a href="/tuev-eintragung" class="text-text-secondary hover:text-burnt transition-colors text-sm">TÜV-Eintragung &rarr;</a>
      <a href="/galerie" class="text-text-secondary hover:text-burnt transition-colors text-sm">Galerie &rarr;</a>
      <a href="/kontakt" class="text-text-secondary hover:text-burnt transition-colors text-sm">Kontakt &rarr;</a>
    </div>
  </div>
</section>

<%- include('../partials/faq-script') %>
<%- include('../layouts/end') %>
