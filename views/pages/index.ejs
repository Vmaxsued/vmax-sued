<!-- ============================================
     LEISTUNGEN — 4 brutalist cards
     ============================================ -->
<section class="section-spacing bg-bg-primary border-t border-border-subtle" id="leistungen">
  <div class="container-vmax">

    <!-- Section header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 lg:mb-20">
      <div>
        <p class="label-caps text-burnt mb-4">01 · Leistungsspektrum</p>
        <h2 class="font-display text-display-section uppercase leading-[0.95]">
          Drei Disziplinen.<br>
          <span class="text-titan">Ein Standard.</span>
        </h2>
      </div>
      <p class="max-w-sm text-text-secondary">
        Jedes Fahrzeug läuft bei uns dieselbe Sequenz: Vermessen, Abstimmen, Dokumentieren. Ohne Ausnahme.
      </p>
    </div>

    <!-- 3 service cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border-subtle border border-border-subtle">

      <!-- Card 1 -->
      <a href="/chiptuning" class="tilt-card group bg-bg-primary p-8 lg:p-12 flex flex-col gap-6 transition-colors duration-300 hover:bg-bg-secondary relative">
        <div class="flex items-start justify-between">
          <span class="font-mono text-xs text-titan/60 tracking-widest">01</span>
          <span class="tag tag-burnt">ab 499 €</span>
        </div>
        <div>
          <h3 class="font-display text-display-card uppercase leading-[0.95] mb-3">
            Chiptuning &<br>Kennfeld&shy;optimierung
          </h3>
          <p class="text-text-secondary text-sm">
            Stage 1, Stage 2, individuelle Abstimmung. Prüfstandgefahren, nicht aus dem Katalog.
          </p>
        </div>
        <div class="mt-auto flex items-center gap-3 font-condensed uppercase tracking-[0.12em] text-sm text-burnt group-hover:text-text-primary transition-colors">
          <span>Zur Leistung</span>
          <span class="w-8 h-px bg-current group-hover:w-12 transition-all duration-300"></span>
          <span aria-hidden="true">→</span>
        </div>
      </a>

      <!-- Card 2 -->
      <a href="/tuev-eintragung" class="tilt-card group bg-bg-primary p-8 lg:p-12 flex flex-col gap-6 transition-colors duration-300 hover:bg-bg-secondary relative">
        <div class="flex items-start justify-between">
          <span class="font-mono text-xs text-titan/60 tracking-widest">02</span>
          <span class="tag tag-burnt">ab 89 €</span>
        </div>
        <div>
          <h3 class="font-display text-display-card uppercase leading-[0.95] mb-3">
            Begleitung zur<br>TÜV-Eintragung
          </h3>
          <p class="text-text-secondary text-sm">
            Vorbereitung Ihres Fahrzeugs und Begleitung zum Termin bei amtlich anerkannten Sachverständigen (GTÜ, Dekra, TÜV Süd).
          </p>
        </div>
        <div class="mt-auto flex items-center gap-3 font-condensed uppercase tracking-[0.12em] text-sm text-burnt group-hover:text-text-primary transition-colors">
          <span>Zur Leistung</span>
          <span class="w-8 h-px bg-current group-hover:w-12 transition-all duration-300"></span>
          <span aria-hidden="true">→</span>
        </div>
      </a>

      <!-- Card 3 -->
      <a href="/b2b" class="tilt-card group bg-bg-primary p-8 lg:p-12 flex flex-col gap-6 transition-colors duration-300 hover:bg-bg-secondary relative">
        <div class="flex items-start justify-between">
          <span class="font-mono text-xs text-titan/60 tracking-widest">03</span>
          <span class="tag tag-titan">B2B</span>
        </div>
        <div>
          <h3 class="font-display text-display-card uppercase leading-[0.95] mb-3">
            Prüftechnik<br>für Firmen
          </h3>
          <p class="text-text-secondary text-sm">
            Prüfstandsmessungen und Datenaufbereitung in Kooperation mit zugelassenen Sachverständigen. Für Tuninghersteller, Importeure und Kfz-Fachbetriebe deutschlandweit.
          </p>
        </div>
        <div class="mt-auto flex items-center gap-3 font-condensed uppercase tracking-[0.12em] text-sm text-burnt group-hover:text-text-primary transition-colors">
          <span>Zur Leistung</span>
          <span class="w-8 h-px bg-current group-hover:w-12 transition-all duration-300"></span>
          <span aria-hidden="true">→</span>
        </div>
      </a>
    </div>
  </div>
</section>


<!-- ============================================
     MANIFEST — brutalist statement
     ============================================ -->
<section class="section-spacing bg-bg-secondary border-t border-border-subtle relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 stripe-band opacity-30"></div>

  <div class="container-vmax">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

      <div class="lg:col-span-7">
        <p class="label-caps text-burnt mb-6">02 · Prinzipien</p>
        <h2 class="font-display uppercase leading-[0.9] text-[clamp(2.5rem,5vw,5.5rem)]">
          Einzelabstimmung.<br>
          <span class="text-stroke-titan">Kein Software-</span><br>
          <span class="text-stroke-titan">paket.</span>
        </h2>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <p class="text-body-lg text-text-primary">
          Zwischen einem gekauften Tuning-File und einer echten Abstimmung liegen <span class="text-burnt">mehrere Stunden Prüfstandarbeit</span>.
        </p>
        <p class="text-text-secondary">
          Wir fahren jedes Fahrzeug auf dem Leistungsprüfstand ein. Wir messen Ist-Werte und passen Kennfelder an die individuelle Mechanik an. Was du bekommst, ist dein Tuning — nicht eine Datei, die jemand anderes gemessen hat. <span class="text-titan">Für Hardware-Verbau und mechanische Umbauten arbeiten wir mit ausgewählten Kfz-Meisterbetriebspartnern zusammen.</span>
        </p>
        <p class="text-titan font-condensed uppercase tracking-wider text-sm">
          → Abgestimmt. Gemessen. Eingetragen.
        </p>
      </div>
    </div>
  </div>
</section>


