            <span class="font-mono text-xs text-text-muted">PS / U/min</span>
          </div>

          <svg viewBox="0 0 500 260" class="w-full h-auto flex-1" aria-hidden="true">
            <!-- Grid -->
            <% for (let i = 0; i <= 5; i++) { %>
              <line x1="<%= 30 + i*90 %>" y1="20" x2="<%= 30 + i*90 %>" y2="220" stroke="#2A2A2A" stroke-width="0.5"/>
            <% } %>
            <% for (let i = 0; i <= 4; i++) { %>
              <line x1="30" y1="<%= 20 + i*50 %>" x2="480" y2="<%= 20 + i*50 %>" stroke="#2A2A2A" stroke-width="0.5"/>
            <% } %>

            <!-- Serie curve (gray dashed) -->
            <path id="dyno-serie-curve" d="<%= dynoCars[0].seriePath %>"
                  fill="none" stroke="#8A8680" stroke-width="2" stroke-linecap="round" stroke-dasharray="4,3" opacity="0.85"/>
            <text x="475" y="155" fill="#8A8680" font-size="10" font-family="JetBrains Mono" text-anchor="end" id="dyno-serie-label">SERIE · 230</text>

            <!-- Stage curve (burnt) -->
            <path id="dyno-stage-curve" d="<%= dynoCars[0].stagePath %>"
                  fill="none" stroke="#C87533" stroke-width="2.5" stroke-linecap="round"
                  stroke-dasharray="600" stroke-dashoffset="600"/>
            <text x="475" y="65" fill="#C87533" font-size="10" font-family="JetBrains Mono" text-anchor="end" id="dyno-stage-label-svg" style="opacity:0">STAGE 2 · 320</text>

            <!-- X-axis labels -->
            <text x="30" y="245" fill="#6B6B6B" font-size="9" font-family="JetBrains Mono">1500</text>
            <text x="120" y="245" fill="#6B6B6B" font-size="9" font-family="JetBrains Mono">2500</text>
            <text x="210" y="245" fill="#6B6B6B" font-size="9" font-family="JetBrains Mono">3500</text>
            <text x="300" y="245" fill="#6B6B6B" font-size="9" font-family="JetBrains Mono">4500</text>
            <text x="390" y="245" fill="#6B6B6B" font-size="9" font-family="JetBrains Mono">5500</text>
            <text x="475" y="245" fill="#6B6B6B" font-size="9" font-family="JetBrains Mono" text-anchor="end">6500</text>
          </svg>

          <!-- Pagination + progress -->
          <div class="mt-6 pt-6 border-t border-border-subtle">
            <div class="flex items-center justify-between gap-4 mb-3">
              <div class="flex gap-2" id="dyno-dots">
                <% dynoCars.forEach(function(_, i) { %>
                  <button type="button" class="dyno-dot w-8 h-1 bg-border-strong transition-colors duration-300 <%= i === 0 ? 'bg-burnt' : '' %>" data-index="<%= i %>" aria-label="Modell <%= i+1 %>"></button>
                <% }); %>
              </div>
              <span class="font-mono text-[11px] text-titan tracking-wider uppercase">
                <span id="dyno-counter">01</span><span class="text-text-muted"> / <%= String(dynoCars.length).padStart(2,'0') %></span>
              </span>
            </div>
            <div class="grid grid-cols-3 gap-6 text-center pt-4 border-t border-border-subtle">
              <div>
                <p class="label-micro text-text-muted">Prüfstand</p>
                <p class="font-mono text-titan text-sm mt-1">Leistungsprüfstand</p>
              </div>
              <div>
                <p class="label-micro text-text-muted">Software</p>
                <p class="font-mono text-titan text-sm mt-1">Einzelabst.</p>
              </div>
              <div>
                <p class="label-micro text-text-muted">Werte</p>
                <p class="font-mono text-titan text-sm mt-1">Beispiel-Lauf</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Disclaimer -->
    <p class="mt-8 font-mono text-[11px] text-text-muted/70 max-w-3xl">
      * Werte aus repräsentativen Kunden-Prüfstandsläufen. Individuelles Ergebnis ist abhängig von Fahrzeugzustand, Mechanik-Reserven und Hardware-Konfiguration. Eintragung erfolgt durch amtlich anerkannten Sachverständigen.
    </p>
  </div>
</section>

<!-- Dyno car data for the rotator -->
<script id="dyno-data" type="application/json"><%- JSON.stringify(dynoCars) %></script>


