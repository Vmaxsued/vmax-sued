                  <p class="font-display text-3xl uppercase leading-[0.95] mb-1">VW Golf 7 R</p>
                  <p class="font-mono text-xs text-text-muted">2.0 TSI · Allrad</p>
                </div>
                <div>
                  <div class="flex items-end gap-3 mb-2">
                    <span class="font-display text-2xl text-text-muted/40 line-through">300</span>
                    <span class="font-mono text-titan">→</span>
                    <span class="font-display text-[68px] text-text-primary leading-none">420</span>
                    <span class="font-condensed uppercase text-titan text-xs mb-2">PS</span>
                  </div>
                  <p class="font-mono text-burnt text-sm">+120 PS · +180 NM</p>
                  <p class="mt-3 flex items-center gap-2 font-mono text-[11px] text-success uppercase tracking-wider">
                    <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                    TÜV-eingetragen
                  </p>
                </div>
              </div>

              <!-- Slide 3 -->
              <div class="showcase-slide p-6 flex flex-col justify-between">
                <div>
                  <p class="font-mono text-[11px] text-titan tracking-widest uppercase mb-3">Projekt 03 · Stage 2+</p>
                  <p class="font-display text-3xl uppercase leading-[0.95] mb-1">BMW M3 F80</p>
                  <p class="font-mono text-xs text-text-muted">3.0 Biturbo · S55</p>
                </div>
                <div>
                  <div class="flex items-end gap-3 mb-2">
                    <span class="font-display text-2xl text-text-muted/40 line-through">431</span>
                    <span class="font-mono text-titan">→</span>
                    <span class="font-display text-[68px] text-text-primary leading-none">560</span>
                    <span class="font-condensed uppercase text-titan text-xs mb-2">PS</span>
                  </div>
                  <p class="font-mono text-burnt text-sm">+129 PS · +210 NM</p>
                  <p class="mt-3 flex items-center gap-2 font-mono text-[11px] text-success uppercase tracking-wider">
                    <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                    TÜV-eingetragen
                  </p>
                </div>
              </div>
            </div>

            <!-- Dots -->
            <div class="flex items-center gap-2 px-6 py-4 border-t border-border-subtle">
              <button class="showcase-dot is-active" data-slide="0" aria-label="Projekt 1"></button>
              <button class="showcase-dot" data-slide="1" aria-label="Projekt 2"></button>
              <button class="showcase-dot" data-slide="2" aria-label="Projekt 3"></button>
              <span class="ml-auto font-mono text-[10px] text-text-muted tracking-widest uppercase" id="showcase-counter">01 / 03</span>
            </div>
          </div>
        </span>
      </div>

    </div>
  </div>

  <!-- Bottom ticker -->
  <div class="absolute bottom-0 left-0 right-0 border-t border-border-subtle bg-bg-primary/90 backdrop-blur-sm py-3 overflow-hidden z-20">
    <div class="flex gap-12 whitespace-nowrap animate-stripe-slide font-mono text-[11px] text-text-muted uppercase tracking-[0.25em]">
      <% for (let i = 0; i < 2; i++) { %>
      <span>● Chiptuning</span>
      <span class="text-titan/40">//</span>
      <span>Einzelabstimmung am Prüfstand</span>
      <span class="text-titan/40">//</span>
      <span>TÜV-Eintragung aus einer Hand</span>
      <span class="text-titan/40">//</span>
      <span>B2B-Prüftechnik</span>
      <span class="text-titan/40">//</span>
      <span>Westendorf · seit 2011</span>
      <span class="text-titan/40">//</span>
      <% } %>
    </div>
  </div>
</section>


