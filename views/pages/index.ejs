<!-- ============================================
     SCROLL REVEAL + COUNTER ANIMATION
     ============================================ -->
<script>
(function() {
  // Scroll Reveal
  const revealElements = document.querySelectorAll('[data-reveal]');

  function reveal() {
    revealElements.forEach(function(el) {
      const top = el.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;

      if (top < windowHeight - 60) {
        const delay = parseInt(el.dataset.delay || 0);
        setTimeout(function() {
          el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, delay);
      }
    });
  }

  // Initial state
  revealElements.forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
  });

  // Hero elements reveal on load
  setTimeout(reveal, 100);
  window.addEventListener('scroll', reveal, { passive: true });

  // Counter Animation
  const counters = document.querySelectorAll('[data-counter]');
  let countersAnimated = false;

  function animateCounters() {
    if (countersAnimated) return;

    counters.forEach(function(counter) {
      const rect = counter.getBoundingClientRect();
      if (rect.top > window.innerHeight) return;

      countersAnimated = true;
      const target = parseInt(counter.dataset.counter);
      const valueEl = counter.querySelector('.counter-value');
      if (!valueEl) return;

      const duration = 2000;
      const start = performance.now();

      function update(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        valueEl.textContent = Math.round(target * eased);

        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }

      requestAnimationFrame(update);
    });
  }

  window.addEventListener('scroll', animateCounters, { passive: true });

  // Ken Burns on hero
  var heroImg = document.querySelector('.hero-bg-image');
  if (heroImg) {
    heroImg.style.transition = 'transform 15s ease-out';
    setTimeout(function() {
      heroImg.style.transform = 'scale(1.08)';
    }, 200);
  }
})();
</script>

