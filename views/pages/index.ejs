<%- include('../layouts/end') %>

<script>
  // 1) HERO LINE-REVEAL — staggered on load
  (function() {
    var lines = document.querySelectorAll('.line-reveal[data-reveal-line]');
    if (!lines.length) return;
    lines.forEach(function(el) {
      var idx = parseInt(el.dataset.revealLine, 10) || 0;
      setTimeout(function() { el.classList.add('is-visible'); }, 240 + idx * 140);
    });
  })();

  // 2) SCROLL-REVEAL — any [data-reveal] becomes visible when near viewport
  (function() {
    var items = document.querySelectorAll('[data-reveal]');
    if (!items.length || !('IntersectionObserver' in window)) {
      items.forEach(function(el) { el.classList.add('is-visible'); });
      return;
    }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.25, rootMargin: '0px 0px -60px 0px' });
    items.forEach(function(el) { io.observe(el); });
  })();

  // 3) MAGNETIC BUTTONS — cursor pull
  (function() {
    if (window.matchMedia('(pointer: coarse)').matches) return;
    document.querySelectorAll('.magnetic').forEach(function(el) {
      var rect;
      el.addEventListener('mouseenter', function() { rect = el.getBoundingClientRect(); });
      el.addEventListener('mousemove', function(e) {
        if (!rect) rect = el.getBoundingClientRect();
        var x = (e.clientX - rect.left - rect.width/2) * 0.22;
        var y = (e.clientY - rect.top - rect.height/2) * 0.28;
        el.style.transform = 'translate(' + x.toFixed(1) + 'px, ' + y.toFixed(1) + 'px)';
      });
      el.addEventListener('mouseleave', function() {
        el.style.transform = '';
        rect = null;
      });
    });
  })();

  // 4) TILT CARDS — 3D hover
  (function() {
    if (window.matchMedia('(pointer: coarse)').matches) return;
    document.querySelectorAll('.tilt-card').forEach(function(el) {
      el.addEventListener('mousemove', function(e) {
        var r = el.getBoundingClientRect();
        var cx = (e.clientX - r.left) / r.width - 0.5;
        var cy = (e.clientY - r.top) / r.height - 0.5;
        el.style.transform = 'perspective(1200px) rotateY(' + (cx * 6).toFixed(2) + 'deg) rotateX(' + (-cy * 6).toFixed(2) + 'deg) translateZ(0)';
      });
      el.addEventListener('mouseleave', function() {
        el.style.transform = '';
      });
    });
  })();

  // 5) HERO SPOTLIGHT — burnt glow follows cursor
  (function() {
    var hero = document.getElementById('hero');
    var spot = document.getElementById('hero-spotlight');
    if (!hero || !spot || window.matchMedia('(pointer: coarse)').matches) return;
    hero.addEventListener('mousemove', function(e) {
      var r = hero.getBoundingClientRect();
      spot.style.left = (e.clientX - r.left) + 'px';
      spot.style.top = (e.clientY - r.top) + 'px';
      spot.style.opacity = '1';
    });
    hero.addEventListener('mouseleave', function() { spot.style.opacity = '0'; });
    spot.style.opacity = '0';
  })();

  // 6) FLAGSHIP SHOWCASE — auto-rotate + dots
  (function() {
    var container = document.getElementById('flagship-showcase');
    if (!container) return;
    var slides = container.querySelectorAll('.showcase-slide');
    var dots = document.querySelectorAll('.showcase-dot');
    var counter = document.getElementById('showcase-counter');
    var idx = 0;
    var paused = false;

    function show(i) {
      idx = (i + slides.length) % slides.length;
      slides.forEach(function(s, k) { s.classList.toggle('is-active', k === idx); });
      dots.forEach(function(d, k) { d.classList.toggle('is-active', k === idx); });
      if (counter) counter.textContent = String(idx+1).padStart(2,'0') + ' / ' + String(slides.length).padStart(2,'0');
    }

    dots.forEach(function(d, k) {
      d.addEventListener('click', function() { show(k); paused = true; setTimeout(function(){ paused = false; }, 8000); });
    });

    setInterval(function() {
      if (document.hidden || paused) return;
      show(idx + 1);
    }, 4000);
  })();

  // 7) DYNO ROTATOR — 5 cars, animated curve + crossfading numbers
  (function() {
    var dataEl = document.getElementById('dyno-data');
    var rotator = document.getElementById('dyno-rotator');
    if (!dataEl || !rotator) return;

    var cars;
    try { cars = JSON.parse(dataEl.textContent); } catch (e) { return; }
    if (!cars || !cars.length) return;

    var stageCurve = document.getElementById('dyno-stage-curve');
    var serieCurve = document.getElementById('dyno-serie-curve');
    var stageLabelSvg = document.getElementById('dyno-stage-label-svg');
    var serieLabel = document.getElementById('dyno-serie-label');
    var stageHeader = document.getElementById('dyno-stage-label');
    var modelEl = document.getElementById('dyno-model');
    var engineEl = document.getElementById('dyno-engine');
    var stockPSEl = document.getElementById('dyno-stockPS');
    var tunedPSEl = document.getElementById('dyno-tunedPS');
    var gainPSEl = document.getElementById('dyno-gainPS');
    var stockNMEl = document.getElementById('dyno-stockNM');
    var tunedNMEl = document.getElementById('dyno-tunedNM');
    var gainNMEl = document.getElementById('dyno-gainNM');
    var counterEl = document.getElementById('dyno-counter');
    var dots = Array.prototype.slice.call(document.querySelectorAll('.dyno-dot'));

    var idx = 0;
    var visible = false;
    var paused = false;

    // Numeric crossfade with count animation
    function setNum(el, target, duration) {
      if (!el) return;
      var start = parseInt(el.textContent.replace(/[^0-9-]/g,''), 10) || 0;
      var sign = (target >= 0 ? '+' : '');
      var prefix = (el.textContent.indexOf('+') === 0) ? sign : '';
      var t0 = performance.now();
      function step(now) {
        var p = Math.min((now - t0) / duration, 1);
        var eased = 1 - Math.pow(1 - p, 3);
        var v = Math.round(start + (target - start) * eased);
        el.textContent = prefix + v;
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function fadeOut(els) {
      els.forEach(function(el) {
        if (!el) return;
        el.style.transition = 'opacity 200ms ease, transform 200ms ease';
        el.style.opacity = '0';
        el.style.transform = 'translateY(-6px)';
      });
    }
    function fadeIn(els) {
      els.forEach(function(el) {
        if (!el) return;
        el.style.opacity = '0';
        el.style.transform = 'translateY(6px)';
        requestAnimationFrame(function() {
          el.style.transition = 'opacity 280ms ease, transform 280ms ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      });
    }

    function render(i, animate) {
      var c = cars[i];
      if (!c) return;

      // Update text content with crossfade
      var textEls = [stageHeader, modelEl, engineEl];
      if (animate) fadeOut(textEls);

      setTimeout(function() {
        if (stageHeader) stageHeader.textContent = c.stage.toUpperCase() + ' · KUNDENBEISPIEL';
        if (modelEl) modelEl.textContent = c.model;
        if (engineEl) engineEl.textContent = c.engine;
        if (animate) fadeIn(textEls);
      }, animate ? 200 : 0);

      // Animate big numbers
      setNum(stockPSEl, c.stockPS, 700);
      setNum(tunedPSEl, c.tunedPS, 1100);
      if (gainPSEl) { gainPSEl.textContent = '+' + c.gainPS; }
      setNum(stockNMEl, c.stockNM, 700);
      setNum(tunedNMEl, c.tunedNM, 1100);
      if (gainNMEl) { gainNMEl.textContent = '+' + c.gainNM; }

      // Update curves
      if (serieCurve) serieCurve.setAttribute('d', c.seriePath);
      if (serieLabel) serieLabel.textContent = 'SERIE · ' + c.stockPS;
      if (stageCurve) {
        stageCurve.setAttribute('d', c.stagePath);
        stageCurve.style.transition = 'none';
        stageCurve.style.strokeDashoffset = '600';
        // Force reflow
        void stageCurve.getBoundingClientRect();
        stageCurve.style.transition = 'stroke-dashoffset 1.6s cubic-bezier(0.22, 1, 0.36, 1)';
        stageCurve.style.strokeDashoffset = '0';
      }
      if (stageLabelSvg) {
        stageLabelSvg.style.opacity = '0';
        stageLabelSvg.textContent = c.stage.toUpperCase() + ' · ' + c.tunedPS;
        setTimeout(function() {
          stageLabelSvg.style.transition = 'opacity 400ms ease';
          stageLabelSvg.style.opacity = '1';
        }, 1200);
      }

      // Dots
      dots.forEach(function(d, di) {
        if (di === i) {
          d.classList.add('bg-burnt');
          d.classList.remove('bg-border-strong');
        } else {
          d.classList.remove('bg-burnt');
          d.classList.add('bg-border-strong');
        }
      });
      if (counterEl) counterEl.textContent = String(i + 1).padStart(2, '0');

      idx = i;
    }

    function next() { render((idx + 1) % cars.length, true); }

    // Manueller Klick pausiert Auto-Rotation für 12 Sekunden, dann wieder weiter
    var pauseUntil = 0;
    dots.forEach(function(d) {
      d.addEventListener('click', function() {
        var i = parseInt(d.dataset.index, 10);
        if (!isNaN(i)) render(i, true);
        pauseUntil = performance.now() + 12000;
      });
    });

    // Initial draw when section first comes into view (animated, nicht statisch)
    function checkInView() {
      if (visible) return;
      var r = rotator.getBoundingClientRect();
      if (r.top < window.innerHeight * 0.85 && r.bottom > 0) {
        visible = true;
        render(0, true);
      }
    }
    window.addEventListener('scroll', checkInView, { passive: true });
    checkInView();

    // Auto-Rotation: läuft auch wenn Cursor über dem Bereich ist.
    // Nur stoppen wenn Tab im Hintergrund oder kurz nach manuellem Klick.
    setInterval(function() {
      if (document.hidden) return;
      if (!visible) return;
      if (performance.now() < pauseUntil) return;
      next();
    }, 5000);
  })();
</script>
