<%- include('../layouts/main') %>

<!-- ============================================
     HERO — Anton Mega · mit Cursor-Spotlight + Line-Reveal
     ============================================ -->
<section class="relative min-h-screen flex items-end overflow-hidden bg-bg-primary pt-32 pb-16 lg:pb-20" id="hero">

  <!-- Background video: Prüfstand-Aufnahme, zentriert & gezoomt um Kennzeichen abzuschneiden -->
  <div class="absolute inset-0 overflow-hidden z-0" aria-hidden="true">
    <video
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-auto h-auto min-w-full min-h-full object-cover scale-[2.2] opacity-[0.7]"
      style="object-position: 20% 70%; filter: saturate(0.8) contrast(1.15) brightness(0.95);"
      autoplay muted loop playsinline preload="auto">
      <source src="/videos/hero.mp4" type="video/mp4">
    </video>
    <!-- Dark gradient overlay — keeps text readable, video stays visible -->
    <div class="absolute inset-0 bg-gradient-to-r from-bg-primary/85 via-bg-primary/40 to-bg-primary/75"></div>
    <!-- Vertical fade bottom-right so text bleibt lesbar -->
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/85 via-transparent to-bg-primary/30"></div>
    <!-- Radial vignette — softer -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 35% 50%, transparent 0%, rgba(10,10,10,0.25) 55%, rgba(10,10,10,0.7) 100%);"></div>
  </div>

  <!-- Carbon weave base -->
  <div class="absolute inset-0 opacity-[0.04] bg-carbon-weave z-[1]" aria-hidden="true"></div>

  <!-- Cursor spotlight — burnt glow follows cursor -->
  <div class="spotlight" id="hero-spotlight" aria-hidden="true"></div>

  <!-- Left vertical rail -->
  <div class="hidden lg:flex absolute left-0 top-0 bottom-0 w-12 flex-col justify-between py-10 z-20 border-r border-border-subtle" aria-hidden="true">
    <span class="font-mono text-[10px] text-titan/50 tracking-[0.3em] [writing-mode:vertical-rl] rotate-180">
      48.4267°N · 10.8742°E
    </span>
    <span class="font-mono text-[10px] text-titan/50 tracking-[0.3em] [writing-mode:vertical-rl] rotate-180">
      VMAX · SÜD · WESTENDORF
    </span>
  </div>

  <!-- Right vertical rail -->
  <div class="hidden lg:flex absolute right-0 top-0 bottom-0 w-12 flex-col justify-between py-10 z-20 border-l border-border-subtle" aria-hidden="true">
    <span class="font-mono text-[10px] text-titan/50 tracking-[0.3em] [writing-mode:vertical-rl]">
      REV · <%= new Date().getFullYear() %>
    </span>
    <span class="font-mono text-[10px] text-burnt tracking-[0.3em] [writing-mode:vertical-rl]">
      ● LIVE · PRÜFSTAND
    </span>
  </div>

  <div class="container-vmax relative z-10 lg:px-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">

      <!-- Headline -->
      <div class="lg:col-span-8">
        <h1 class="font-display text-display-mega leading-[0.88] tracking-[-0.015em] uppercase">
          <span class="line-reveal" data-reveal-line="1"><span>Leistung.</span></span>
          <span class="line-reveal" data-reveal-line="2"><span>Eingetragen.</span></span>
          <span class="line-reveal" data-reveal-line="3"><span class="text-burnt">Vertrauen erfahren.</span></span>
        </h1>

        <p class="mt-10 max-w-xl text-text-secondary text-lg leading-relaxed line-reveal" data-reveal-line="4">
          <span>Einzelabstimmung auf dem Prüfstand. TÜV-Eintragung komplett aus einer Hand. <span class="text-titan">Keine Softwarepakete von der Stange.</span></span>
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-12 line-reveal" data-reveal-line="5">
          <span class="flex flex-col sm:flex-row gap-4">
            <span class="magnetic">
              <a href="/kontakt" class="btn-cta">
                Termin anfragen <span aria-hidden="true">→</span>
              </a>
            </span>
            <span class="magnetic">
              <a href="#leistungen" class="btn-primary">
                Leistungsspektrum
              </a>
            </span>
          </span>
        </div>
      </div>

      <!-- Flagship Showcase (rotiert, PLATZHALTER) -->
      <div class="lg:col-span-4 mt-12 lg:mt-0 line-reveal" data-reveal-line="3">
        <span class="block">
          <div class="tilt-card border-2 border-border-strong bg-bg-secondary/80 backdrop-blur-sm relative min-h-[440px] flex flex-col">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-3 border-b border-border-subtle">
              <span class="label-micro text-burnt flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-burnt animate-glow-pulse"></span>
                Flagship-Projekte
              </span>
