                  <p class="font-mono text-xs text-text-muted">2.5 TFSI · DAZA</p>
                </div>
                <div>
                  <div class="flex items-end gap-3 mb-2">
                    <span class="font-display text-2xl text-text-muted/40 line-through">367</span>
                    <span class="font-mono text-titan">→</span>
                    <span class="font-display text-[68px] text-text-primary leading-none">480</span>
                    <span class="font-condensed uppercase text-titan text-xs mb-2">PS</span>
                  </div>
