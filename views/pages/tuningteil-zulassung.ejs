<%- include('../layouts/main') %>

<!-- Hero -->
<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
  <div class="absolute inset-0 bg-bg-secondary">
    <div class="absolute inset-0" style="background-image: url('/images/vehicles/b2b-hero.jpg'); background-size: cover; background-position: center;"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/85 to-bg-primary/40"></div>
  </div>
  <div class="container-vmax relative z-10">
    <nav class="mb-8 text-sm text-text-muted" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text-secondary transition-colors">Start</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">Tuningteil-Zulassung</span>
    </nav>
    <span class="label-caps text-burnt block mb-4">Für Hersteller, Importeure &amp; Tuning-Marken</span>
    <h1 class="font-display text-4xl md:text-5xl lg:text-display-section uppercase tracking-tight leading-[1.15] max-w-4xl">
      Tuningteil-Zulassung:<br class="hidden md:block"> <span class="text-text-secondary">Vom Prototyp zum fertigen Gutachten.</span>
    </h1>
    <p class="mt-6 text-lg text-text-secondary max-w-2xl">
      Wählen Sie Produkt und Zielmarkt — und sehen Sie sofort, welcher Zulassungsweg gilt, welche Prüfstandsmessungen nötig sind und wie aufwendig der Weg zum fertigen Gutachten ist.
    </p>
  </div>
</section>

<!-- Zulassungs-Navigator -->
<section class="section-spacing" id="navigator">
  <div class="container-vmax">
    <span class="label-caps text-burnt block mb-4">Zulassungs-Navigator</span>
    <h2 class="font-display text-2xl md:text-display-card uppercase tracking-tight text-text-primary mb-10">
      Welches Gutachten braucht Ihr Tuningteil?
    </h2>

    <div class="border border-border-subtle bg-bg-secondary">
      <!-- Tool-Header -->
      <div class="flex items-center gap-3 px-6 py-4 border-b border-border-subtle">
        <span class="w-2 h-2 rounded-full bg-burnt shadow-[0_0_10px_theme(colors.burnt)]"></span>
        <span class="font-mono text-xs tracking-widest text-text-muted uppercase">Erstorientierung für Hersteller &amp; Importeure</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Inputs -->
        <div class="p-6 lg:p-8 lg:border-r border-border-subtle space-y-8">

          <!-- Produktkategorie -->
          <div>
            <span class="font-mono text-xs tracking-widest uppercase text-text-muted block mb-4">01 — <span class="text-burnt">Produktkategorie</span></span>
            <div class="flex flex-wrap gap-2" id="cat"></div>
          </div>

          <!-- Zielmarkt -->
          <div>
            <span class="font-mono text-xs tracking-widest uppercase text-text-muted block mb-4">02 — <span class="text-burnt">Zielmarkt</span></span>
            <div class="flex border border-border-subtle" id="market"></div>
          </div>

          <!-- Fahrzeug-Umfang -->
          <div>
            <span class="font-mono text-xs tracking-widest uppercase text-text-muted block mb-4">03 — <span class="text-burnt">Fahrzeug-Umfang</span></span>
            <div class="flex border border-border-subtle" id="scope"></div>
          </div>
        </div>

        <!-- Result -->
        <div class="p-6 lg:p-8 flex flex-col gap-6" id="result">

          <div>
            <p class="font-mono text-xs tracking-widest uppercase text-text-muted mb-2">Empfohlener Zulassungsweg</p>
            <p class="font-display text-xl md:text-2xl uppercase tracking-tight text-text-primary leading-tight" id="docOut">
              <span class="text-text-muted">Bitte oben eine Produktkategorie wählen.</span>
            </p>
            <p class="text-text-secondary text-sm mt-2" id="marketOut"></p>
          </div>

          <!-- Path Track -->
          <div id="trackWrap" class="hidden">
            <p class="font-mono text-xs tracking-widest uppercase text-text-muted mb-4">Weg zum Gutachten</p>
            <div class="relative flex justify-between mb-6" id="track">
              <div class="absolute top-[9px] left-[9px] right-[9px] h-[2px] bg-border-subtle"></div>
              <div class="absolute top-[9px] left-[9px] h-[2px] bg-burnt transition-all duration-700 ease-out" id="trackFill" style="width:0"></div>
              <div class="station relative z-10 flex flex-col items-center flex-1 text-center">
                <div class="node w-5 h-5 rounded-full bg-bg-tertiary border-2 border-border-subtle mb-2 transition-all duration-300"></div>
                <span class="cap text-[10px] text-text-muted leading-tight max-w-[8ch] transition-colors duration-300">Erst­prüfung &amp; Messung</span>
              </div>
              <div class="station relative z-10 flex flex-col items-center flex-1 text-center">
                <div class="node w-5 h-5 rounded-full bg-bg-tertiary border-2 border-border-subtle mb-2 transition-all duration-300"></div>
                <span class="cap text-[10px] text-text-muted leading-tight max-w-[8ch] transition-colors duration-300">Daten­aufbereitung</span>
              </div>
              <div class="station relative z-10 flex flex-col items-center flex-1 text-center">
                <div class="node w-5 h-5 rounded-full bg-bg-tertiary border-2 border-border-subtle mb-2 transition-all duration-300"></div>
                <span class="cap text-[10px] text-text-muted leading-tight max-w-[8ch] transition-colors duration-300">Akkreditierte Prüfstelle</span>
              </div>
              <div class="station relative z-10 flex flex-col items-center flex-1 text-center">
                <div class="node w-5 h-5 rounded-full bg-bg-tertiary border-2 border-border-subtle mb-2 transition-all duration-300"></div>
                <span class="cap text-[10px] text-text-muted leading-tight max-w-[8ch] transition-colors duration-300">Fertiges Gutachten</span>
              </div>
            </div>
          </div>

          <!-- Messungen -->
          <div id="testsWrap" class="hidden">
            <p class="font-mono text-xs tracking-widest uppercase text-text-muted mb-3">Erforderliche Messungen bei Vmax Sued</p>
            <div id="testsOut" class="space-y-0 divide-y divide-border-subtle"></div>
          </div>

          <!-- Aufwand -->
          <div id="effortWrap" class="hidden">
            <div class="flex justify-between items-baseline mb-2">
              <span class="font-mono text-xs tracking-widest uppercase text-text-muted">Aufwand-Indikator</span>
              <span class="font-display text-sm uppercase tracking-tight" id="effortVal">—</span>
            </div>
            <div class="flex gap-1.5">
              <div class="h-1.5 flex-1 bg-border-subtle transition-colors duration-300" id="e1"></div>
              <div class="h-1.5 flex-1 bg-border-subtle transition-colors duration-300" id="e2"></div>
              <div class="h-1.5 flex-1 bg-border-subtle transition-colors duration-300" id="e3"></div>
            </div>
          </div>

          <p class="text-text-muted text-xs leading-relaxed border-l-2 border-border-strong pl-3">
            Orientierung, keine Rechtsberatung. Der finale Genehmigungsweg wird im Einzelfall mit der akkreditierten Prüfstelle festgelegt.
          </p>

          <a id="cta" href="mailto:stefan_jung@vmax-sued.com?subject=B2B-Anfrage%20Tuningteil-Zulassung" class="btn-primary inline-flex items-center justify-center gap-2 mt-auto">
            Projekt anfragen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Erklärblock -->
<section class="section-spacing bg-bg-secondary border-t border-border-subtle">
  <div class="container-vmax">
    <span class="label-caps text-burnt block mb-4">Grundlagen</span>
    <h2 class="font-display text-2xl md:text-display-card uppercase tracking-tight text-text-primary mb-4">
      ABE, Teilegutachten oder ECE — wo liegt der Unterschied?
    </h2>
    <p class="text-text-secondary text-lg leading-relaxed max-w-3xl mb-10">
      Wer Tuningteile zulassen lassen möchte, stößt schnell auf drei unterschiedliche Wege. Welcher passt, hängt von Produkt, Zielmarkt und geplantem Vertriebsweg ab.
    </p>

    <div class="space-y-6 max-w-4xl">
      <div class="border border-border-subtle bg-bg-tertiary p-6 md:p-8">
        <div class="flex flex-col md:flex-row md:items-start gap-6">
          <div class="md:w-48 flex-shrink-0">
            <p class="font-mono text-burnt text-xs uppercase tracking-wider mb-1">§ 22 StVZO · DE</p>
            <h3 class="font-display text-xl uppercase tracking-tight text-text-primary">ABE</h3>
            <p class="text-text-muted text-xs mt-1">Allgemeine Betriebserlaubnis</p>
          </div>
          <div class="flex-1 text-text-secondary text-sm leading-relaxed space-y-2">
            <p>Bundesweit gültige Vorabgenehmigung für ein Bauteil an definierten Fahrzeugtypen. Erteilt vom Kraftfahrt-Bundesamt. Der Endkunde baut das Teil oft ohne Einzelabnahme ein.</p>
            <p><span class="text-text-primary">Geeignet für:</span> Serienteile mit breiter Fahrzeugabdeckung. Hoher Initialaufwand, danach maximaler Komfort für Endkunden und Handel.</p>
          </div>
        </div>
      </div>

      <div class="border border-border-subtle bg-bg-tertiary p-6 md:p-8">
        <div class="flex flex-col md:flex-row md:items-start gap-6">
          <div class="md:w-48 flex-shrink-0">
            <p class="font-mono text-burnt text-xs uppercase tracking-wider mb-1">§ 19.3 StVZO · DE</p>
            <h3 class="font-display text-xl uppercase tracking-tight text-text-primary">Teilegutachten</h3>
            <p class="text-text-muted text-xs mt-1">Abnahme beim Sachverständigen</p>
          </div>
          <div class="flex-1 text-text-secondary text-sm leading-relaxed space-y-2">
            <p>Bestätigt die technische Unbedenklichkeit eines Bauteils. Der Endkunde lässt das Teil beim Sachverständigen (GTÜ, Dekra, TÜV) eintragen. <a href="/tuev-eintragung" class="text-burnt hover:underline">Diesen Schritt übernehmen wir auf Wunsch komplett &rarr;</a></p>
            <p><span class="text-text-primary">Geeignet für:</span> Häufigster Weg bei Fahrwerk, Felgen, Auspuffanlagen und Leistungssteigerungen.</p>
          </div>
        </div>
      </div>

      <div class="border border-border-subtle bg-bg-tertiary p-6 md:p-8">
        <div class="flex flex-col md:flex-row md:items-start gap-6">
          <div class="md:w-48 flex-shrink-0">
            <p class="font-mono text-burnt text-xs uppercase tracking-wider mb-1">UNECE · INT</p>
            <h3 class="font-display text-xl uppercase tracking-tight text-text-primary">ECE-Typgenehmigung</h3>
            <p class="text-text-muted text-xs mt-1">z. B. R90 Bremsen, R59 Auspuff</p>
          </div>
          <div class="flex-1 text-text-secondary text-sm leading-relaxed space-y-2">
            <p>Internationales Regelwerk der UNECE, gültig in 60+ Unterzeichnerstaaten. Der Weg für Export über Deutschland und Europa hinaus.</p>
            <p><span class="text-text-primary">Geeignet für:</span> Hersteller mit Export-Ambitionen. Märkte außerhalb des UNECE-Abkommens (z. B. USA) brauchen einen eigenen Nachweis.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section-spacing">
  <div class="container-vmax max-w-3xl">
    <span class="label-caps text-burnt block mb-4">Häufige Fragen</span>
    <h2 class="font-display text-2xl md:text-display-card uppercase tracking-tight mb-10">Tuningteil-Zulassung — FAQ</h2>
    <div class="space-y-4">
      <% faq.forEach(function(item) { %>
      <div class="border border-border-subtle bg-bg-tertiary">
        <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
          <span class="text-text-primary font-medium text-sm pr-4"><%= item.q %></span>
          <svg class="w-5 h-5 text-burnt flex-shrink-0 faq-icon transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5">
          <p class="text-text-secondary text-sm leading-relaxed"><%= item.a %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Related Links -->
<section class="py-16 border-t border-border-subtle">
  <div class="container-vmax">
    <p class="text-text-muted text-sm">Weiterführend</p>
    <div class="flex flex-wrap gap-x-6 gap-y-2 mt-2">
      <a href="/b2b" class="text-text-secondary hover:text-burnt transition-colors text-sm">B2B-Prüftechnik &rarr;</a>
      <a href="/tuev-eintragung" class="text-text-secondary hover:text-burnt transition-colors text-sm">TÜV-Eintragung &rarr;</a>
      <a href="/chiptuning" class="text-text-secondary hover:text-burnt transition-colors text-sm">Kennfeldoptimierung &rarr;</a>
      <a href="/kontakt" class="text-text-secondary hover:text-burnt transition-colors text-sm">Kontakt &rarr;</a>
    </div>
  </div>
</section>

<%- include('../partials/faq-script') %>

<script>
(function(){
  const CATEGORIES = {
    abgas:     { label:'Abgasanlage / Sportauspuff',           tests:['geraeusch','abgas','leistung'],    deDoc:'ABE oder Teilegutachten (§&thinsp;19.3 StVZO)', ece:'ECE-R59 – Austausch-Schalldämpferanlage', base:2 },
    leistung:  { label:'Leistungssteigerung / Kennfeldoptimierung', tests:['leistung','abgas','geraeusch'], deDoc:'Teilegutachten (§&thinsp;19.3 StVZO)',          ece:'EU-Typgenehmigung je Variante',             base:3 },
    fahrwerk:  { label:'Fahrwerk (Federn / Gewindefahrwerk)',  tests:['festigkeit','bremsen'],            deDoc:'Teilegutachten + Festigkeitsnachweis',           ece:'überwiegend national',                      base:2 },
    felgen:    { label:'Felgen / Räder',                       tests:['festigkeit','bremsen'],            deDoc:'Teilegutachten / Festigkeitsgutachten',          ece:'überwiegend national',                      base:2 },
    bremsen:   { label:'Bremsanlage',                          tests:['bremsen','festigkeit'],            deDoc:'Teilegutachten',                                 ece:'ECE-R90 – Austausch-Bremsbauteile',         base:3 },
    ansaugung: { label:'Ansaugung / Luftfilter',               tests:['leistung','abgas','geraeusch'],    deDoc:'ABE oder Teilegutachten',                        ece:'überwiegend national',                      base:1 },
    karosserie:{ label:'Karosserie / Aero / Anbauteile',       tests:['festigkeit'],                      deDoc:'Teilegutachten (§&thinsp;19.3 StVZO)',           ece:'überwiegend national',                      base:1 }
  };
  const TESTS = {
    leistung:  'Leistungsmessung am Prüfstand',
    abgas:     'Abgas- &amp; Emissionsmessung (Euro 0–7)',
    geraeusch: 'Geräuschmessung nach StVZO',
    festigkeit:'Festigkeit &amp; Fahrversuch',
    bremsen:   'Bremsenprüfung'
  };
  const MARKETS = {
    de:  { label:'Nur Deutschland', add:0, note:'Erstellung durch akkreditierte Stelle in DE — GTÜ / Dekra / TÜV Süd.' },
    eu:  { label:'EU-weit',         add:1, note:'EU-/EG-Typgenehmigung, sofern eine Regelung existiert — sonst nationaler Weg je Mitgliedsstaat.' },
    welt:{ label:'Weltweit',        add:2, note:'ECE gilt in 60+ UNECE-Staaten. Märkte außerhalb (z. B. USA: FMVSS / EPA / CARB) brauchen einen eigenen Nachweis.' }
  };
  const SCOPE = {
    single:   { label:'Ein Modell',  add:0 },
    multi:    { label:'Mehrere',     add:1 },
    universal:{ label:'Universal',   add:2 }
  };

  const state = { cat:null, market:'de', scope:'single' };

  // ---- build chip buttons ----
  const catEl = document.getElementById('cat');
  Object.entries(CATEGORIES).forEach(([k,v]) => {
    const b = document.createElement('button');
    b.className = 'font-condensed text-sm uppercase tracking-wide px-3 py-2 border border-border-subtle bg-bg-tertiary text-text-muted hover:text-text-primary hover:border-burnt transition-colors cursor-pointer';
    b.textContent = v.label;
    b.setAttribute('aria-pressed','false');
    b.dataset.k = k;
    b.onclick = () => { state.cat = k; syncChips(); render(); };
    catEl.appendChild(b);
  });

  // ---- build segment buttons ----
  buildSeg('market', MARKETS, 'market');
  buildSeg('scope',  SCOPE,   'scope');

  function buildSeg(id, obj, key) {
    const el = document.getElementById(id);
    Object.entries(obj).forEach(([k,v], i, arr) => {
      const b = document.createElement('button');
      b.className = 'flex-1 font-condensed text-xs uppercase tracking-wide py-2.5 px-3 text-text-muted hover:text-text-primary transition-colors cursor-pointer' + (i < arr.length-1 ? ' border-r border-border-subtle' : '');
      b.textContent = v.label;
      b.dataset.k = k;
      b.dataset.key = key;
      b.setAttribute('aria-pressed', state[key] === k ? 'true' : 'false');
      b.onclick = () => { state[key] = k; syncSeg(id, key); render(); };
      el.appendChild(b);
    });
  }

  function syncChips() {
    document.querySelectorAll('#cat button').forEach(b => {
      const on = b.dataset.k === state.cat;
      b.setAttribute('aria-pressed', on ? 'true':'false');
      b.classList.toggle('bg-burnt',       on);
      b.classList.toggle('border-burnt',   on);
      b.classList.toggle('text-bg-primary',on);
      b.classList.toggle('font-semibold',  on);
      b.classList.toggle('bg-bg-tertiary', !on);
      b.classList.toggle('text-text-muted',!on);
    });
  }

  function syncSeg(id, key) {
    document.querySelectorAll('#'+id+' button').forEach(b => {
      const on = b.dataset.k === state[key];
      b.setAttribute('aria-pressed', on ? 'true':'false');
      b.classList.toggle('bg-burnt',        on);
      b.classList.toggle('text-bg-primary', on);
      b.classList.toggle('font-semibold',   on);
      b.classList.toggle('text-text-muted', !on);
    });
  }

  function render() {
    if (!state.cat) return;
    const c = CATEGORIES[state.cat];
    const m = MARKETS[state.market];
    const s = SCOPE[state.scope];

    // doc
    let doc;
    if (state.market === 'de')   doc = c.deDoc;
    else if (state.market === 'eu') doc = 'EU-Typgenehmigung, sonst: ' + c.deDoc;
    else doc = (c.ece.includes('ECE')||c.ece.includes('EU')) ? c.ece + ' + nationale Ergänzung' : 'Nationaler Weg (' + c.deDoc + ') je Zielmarkt';

    document.getElementById('docOut').innerHTML = doc;
    document.getElementById('marketOut').textContent = m.note;

    // tests
    const tOut = document.getElementById('testsOut');
    tOut.innerHTML = '';
    c.tests.forEach(t => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 py-2.5 text-sm text-text-secondary';
      row.innerHTML = '<span class="w-5 h-5 bg-burnt text-bg-primary flex-shrink-0 grid place-items-center font-mono text-xs font-bold">✓</span>' + TESTS[t];
      tOut.appendChild(row);
    });

    // effort
    const score = c.base + m.add + s.add;
    let level, lit, color;
    if (score <= 2)      { level='Niedrig'; lit=1; color='text-success'; bc='bg-success'; }
    else if (score <= 4) { level='Mittel';  lit=2; color='text-burnt';   bc='bg-burnt';   }
    else                 { level='Hoch';    lit=3; color='text-error';   bc='bg-error';   }

    const ev = document.getElementById('effortVal');
    ev.textContent = level;
    ev.className = 'font-display text-sm uppercase tracking-tight ' + color;
    [1,2,3].forEach(i => {
      const el = document.getElementById('e'+i);
      el.className = 'h-1.5 flex-1 transition-colors duration-300 ' + (i <= lit ? bc : 'bg-border-subtle');
    });

    // show hidden elements
    ['trackWrap','testsWrap','effortWrap'].forEach(id => {
      document.getElementById(id).classList.remove('hidden');
    });

    // animate track
    animateTrack();

    // cta mailto
    const body = encodeURIComponent('Produkt: '+c.label+'\nZielmarkt: '+m.label+'\nFahrzeug-Umfang: '+s.label+'\n\nKurzbeschreibung:\n');
    document.getElementById('cta').href = 'mailto:stefan_jung@vmax-sued.com?subject=' + encodeURIComponent('B2B-Anfrage Zulassung: '+c.label) + '&body=' + body;
  }

  let timers = [];
  function animateTrack() {
    timers.forEach(clearTimeout); timers = [];
    const stations = document.querySelectorAll('.station');
    const fill = document.getElementById('trackFill');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    stations.forEach(s => {
      s.querySelector('.node').classList.remove('bg-burnt','border-burnt','shadow-[0_0_0_4px_rgba(200,117,51,0.2)]');
      s.querySelector('.node').classList.add('bg-bg-tertiary','border-border-subtle');
      s.querySelector('.cap').classList.remove('text-text-primary');
      s.querySelector('.cap').classList.add('text-text-muted');
    });
    fill.style.width = '0';

    if (reduced) {
      fill.style.transition = 'none';
      fill.style.width = 'calc(100% - 20px)';
      stations.forEach(s => activateStation(s));
      return;
    }

    fill.style.transition = 'width 0.8s cubic-bezier(0.4,0,0.2,1)';
    requestAnimationFrame(() => { fill.style.width = 'calc(100% - 20px)'; });
    stations.forEach((s, i) => {
      timers.push(setTimeout(() => activateStation(s), 120 + i * 200));
    });
  }

  function activateStation(s) {
    const node = s.querySelector('.node');
    const cap  = s.querySelector('.cap');
    node.classList.remove('bg-bg-tertiary','border-border-subtle');
    node.classList.add('bg-burnt','border-burnt','shadow-[0_0_0_4px_rgba(200,117,51,0.2)]');
    cap.classList.remove('text-text-muted');
    cap.classList.add('text-text-primary');
  }
})();
</script>

<%- include('../layouts/end') %>
