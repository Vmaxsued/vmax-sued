<%- include('../layouts/main') %>

<!-- Hero -->
<section class="pt-32 pb-12 lg:pt-40 lg:pb-16">
  <div class="container-vmax">
    <nav class="font-mono text-[11px] tracking-wider text-titan/60 uppercase mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text-primary transition-colors">Start</a>
      <span class="mx-2">/</span>
      <span class="text-burnt">Galerie</span>
    </nav>
    <div class="flex items-center gap-3 mb-6">
      <span class="slash-accent"></span>
      <span class="label-caps text-titan">Echte Kundenfahrzeuge · Prüfstand-Impressionen</span>
    </div>
    <h1 class="font-display text-display-hero uppercase leading-[0.95] tracking-tight">
      Projekte vom<br><span class="text-burnt">Prüfstand.</span>
    </h1>
    <p class="mt-6 text-lg text-text-secondary max-w-2xl">
      Kundenfahrzeuge, Prüfstands-Sessions und abgeschlossene Projekte. Echte Ergebnisse aus Westendorf — kein Stock-Material.
    </p>
  </div>
</section>

<!-- Filter -->
<section class="pb-8">
  <div class="container-vmax">
    <div class="flex flex-wrap gap-2" id="gallery-filters">
      <button class="gallery-filter active font-condensed uppercase tracking-wider px-4 py-2 text-xs border border-border-subtle bg-bg-tertiary text-text-primary transition-colors" data-filter="all">Alle</button>
      <button class="gallery-filter font-condensed uppercase tracking-wider px-4 py-2 text-xs border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="bmw">BMW</button>
      <button class="gallery-filter font-condensed uppercase tracking-wider px-4 py-2 text-xs border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="audi">Audi</button>
      <button class="gallery-filter font-condensed uppercase tracking-wider px-4 py-2 text-xs border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="vw">VW</button>
      <button class="gallery-filter font-condensed uppercase tracking-wider px-4 py-2 text-xs border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="ford">Ford</button>
    </div>
  </div>
</section>

<!-- Masonry Grid -->
<section class="pb-section-mobile lg:pb-section">
  <div class="container-vmax">
    <div class="columns-1 md:columns-2 lg:columns-3 gap-5 space-y-5" id="gallery-grid">

      <% var galleryItems = [
        // Neue Bilder (Juni 2026)
        { img: '/images/vehicles/opt-11.jpg', brand: 'bmw',       label: 'BMW M3 Competition',        desc: 'Auf dem Prüfstand · Isle of Man Green',     tall: false },
        { img: '/images/vehicles/opt-13.jpg', brand: 'bmw',       label: 'BMW M3 · F80',              desc: 'Im Test Center · Westendorf',               tall: true  },
        { img: '/images/vehicles/opt-14.jpg', brand: 'bmw',       label: 'BMW M4 · S55 + Eventuri',   desc: 'Motorraum · M Power S55 Twin-Turbo',        tall: false },
        { img: '/images/vehicles/opt-12.jpg', brand: 'bmw',       label: 'BMW 4er Gran Coupé',        desc: 'Schwarz · Einzelabstimmung am Prüfstand',   tall: false },
        { img: '/images/vehicles/opt-17.jpg', brand: 'audi',      label: 'Audi RS3 8V Sportback',     desc: 'Auf dem Prüfstand · Heckansicht',           tall: false },
        { img: '/images/vehicles/opt-15.jpg', brand: 'audi',      label: 'Audi RS6 C6 · V10 TFSI',    desc: 'Motorraum · V10-Biturbo Detail',            tall: true  },
        { img: '/images/vehicles/opt-16.jpg', brand: 'vw',        label: 'VW Golf 7 R + Polo GTI',    desc: 'Doppelpack · Kundenfahrzeuge',              tall: true  },
        // Alte Bilder (selektiert)
        { img: '/images/vehicles/opt-06.jpg', brand: 'ford',      label: 'Ford Focus RS Mk2',         desc: 'Kennfeldoptimierung · Stage 1',             tall: false },
        { img: '/images/vehicles/opt-08.jpg', brand: 'ford',      label: 'Ford Focus RS Mk2',         desc: 'Heckansicht · nach Abstimmung',             tall: false },
        { img: '/images/vehicles/opt-09.jpg', brand: 'ford',      label: 'Ford Focus RS Mk2',         desc: 'Bühne · Vorbereitung Eintragung',           tall: true  }
      ]; %>

      <% galleryItems.forEach(function(item) { %>
      <div class="gallery-item break-inside-avoid group cursor-pointer" data-brand="<%= item.brand %>">
        <div class="relative overflow-hidden border border-border-subtle bg-bg-tertiary hover:border-burnt transition-colors duration-300">
          <img src="<%= item.img %>" alt="<%= item.label %>"
               class="w-full <%= item.tall ? 'h-[460px]' : 'h-[280px]' %> object-cover group-hover:scale-105 transition-transform duration-700"
               loading="lazy" decoding="async">
          <!-- Permanent label overlay (subtle) -->
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-bg-primary/95 via-bg-primary/40 to-transparent p-5">
            <p class="font-condensed uppercase tracking-wider text-text-primary text-sm font-semibold"><%= item.label %></p>
            <p class="font-mono text-[11px] text-titan mt-1"><%= item.desc %></p>
          </div>
          <!-- Hover overlay with zoom hint -->
          <div class="absolute top-3 right-3 w-9 h-9 bg-bg-primary/80 border border-border-strong flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <svg class="w-4 h-4 text-burnt" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8.25V18a2.25 2.25 0 002.25 2.25h13.5A2.25 2.25 0 0021 18V8.25m-18 0V6a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 6v2.25m-18 0h18M5.25 6h.008v.008H5.25V6zM7.5 6h.008v.008H7.5V6zm2.25 0h.008v.008H9.75V6z"/></svg>
          </div>
        </div>
      </div>
      <% }); %>

    </div>

    <div class="mt-12 text-center">
      <p class="font-mono text-[11px] text-text-muted/70 tracking-wider uppercase">Bilder aus dem Archiv von Vmax Sued · weitere Kundenfahrzeuge werden laufend ergänzt</p>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="fixed inset-0 z-50 bg-bg-primary/95 backdrop-blur-md hidden flex items-center justify-center" id="lightbox">
  <button class="absolute top-6 right-6 text-text-muted hover:text-text-primary transition-colors" id="lightbox-close" aria-label="Schließen">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <img src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain" id="lightbox-img">
</div>

<!-- CTA -->
<section class="py-20 border-t border-border-subtle">
  <div class="container-vmax text-center">
    <p class="font-display text-3xl md:text-4xl uppercase tracking-tight text-text-primary mb-3">
      Ihr Fahrzeug soll das nächste Projekt sein?
    </p>
    <p class="text-text-secondary text-base mb-8 max-w-xl mx-auto">
      Termin anfragen — wir prüfen Machbarkeit, Stage-Optionen und Eintragungs-Aussichten. Festpreis-Angebot binnen 24 Stunden.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/kontakt" class="btn-cta">Termin anfragen <span aria-hidden="true">→</span></a>
      <a href="tel:<%= phone %>" class="btn-primary">Direkt anrufen</a>
    </div>
  </div>
</section>

<script>
(function() {
  // Filter
  document.querySelectorAll('.gallery-filter').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = this.dataset.filter;
      document.querySelectorAll('.gallery-filter').forEach(function(b) {
        b.classList.remove('active', 'bg-bg-tertiary', 'text-text-primary');
        b.classList.add('text-text-muted');
      });
      this.classList.add('active', 'bg-bg-tertiary', 'text-text-primary');
      this.classList.remove('text-text-muted');

      document.querySelectorAll('.gallery-item').forEach(function(item) {
        if (filter === 'all' || item.dataset.brand === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // Lightbox
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');

  document.querySelectorAll('.gallery-item').forEach(function(item) {
    item.addEventListener('click', function() {
      var img = this.querySelector('img');
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', function(e) { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox(); });

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }
})();
</script>

<%- include('../layouts/end') %>
