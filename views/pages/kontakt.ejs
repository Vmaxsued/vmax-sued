<%- include('../layouts/main') %>

<!-- Hero -->
<section class="pt-32 pb-12 lg:pt-40 lg:pb-16">
  <div class="container-vmax">
    <nav class="mb-8 text-sm text-text-muted" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text-secondary transition-colors">Start</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">Kontakt</span>
    </nav>
    <span class="label-caps text-burnt block mb-4">Kontakt</span>
    <h1 class="font-display text-4xl md:text-5xl lg:text-display-section font-medium uppercase tracking-tight leading-[1.05] max-w-3xl">
      Termin anfragen
    </h1>
    <p class="mt-4 text-lg text-text-secondary max-w-2xl">
      Nennen Sie uns Ihr Fahrzeug und Ihren Wunsch — wir melden uns innerhalb von 24&nbsp;Stunden bei Ihnen.
    </p>
  </div>
</section>

<!-- Wizard + Sidebar -->
<section class="pb-section-mobile lg:pb-section">
  <div class="container-vmax">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <!-- Wizard -->
      <div class="lg:col-span-7">

        <!-- Progress Bar -->
        <div class="mb-10">
          <div class="flex items-center justify-between mb-3">
            <span class="label-caps text-text-muted">Schritt <span id="step-current">1</span> von 4</span>
            <span class="label-caps text-text-muted" id="step-label">Fahrzeug</span>
          </div>
          <div class="w-full h-1 bg-bg-tertiary rounded-full overflow-hidden">
            <div class="h-full bg-burnt transition-all duration-500 rounded-full" id="progress-bar" style="width: 25%"></div>
          </div>
        </div>

        <form id="contact-form" novalidate>

          <!-- STEP 1: Fahrzeug -->
          <div class="wizard-step" data-step="1">
            <h2 class="font-display text-2xl font-medium uppercase tracking-tight mb-6">Ihr Fahrzeug</h2>

            <div class="space-y-5">
              <div>
                <label for="v-brand" class="block text-sm text-text-secondary mb-2">Marke *</label>
                <select id="v-brand" name="vehicle_brand" required
                  class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm focus:outline-none focus:border-burnt transition-colors appearance-none">
                  <option value="">Marke wählen</option>
                  <option>Audi</option>
                  <option>BMW</option>
                  <option>CUPRA</option>
                  <option>Mercedes-Benz</option>
                  <option>Porsche</option>
                  <option>SEAT</option>
                  <option>Škoda</option>
                  <option>Volkswagen</option>
                  <option>Andere</option>
                </select>
              </div>
              <div>
                <label for="v-model" class="block text-sm text-text-secondary mb-2">Modell *</label>
                <input type="text" id="v-model" name="vehicle_model" required placeholder="z.B. Golf 7 GTI, RS3 8V, A4 B9 ..."
                  class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors">
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="v-year" class="block text-sm text-text-secondary mb-2">Baujahr</label>
                  <input type="text" id="v-year" name="vehicle_year" placeholder="z.B. 2019"
                    class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors">
                </div>
                <div>
                  <label for="v-engine" class="block text-sm text-text-secondary mb-2">Motorisierung</label>
                  <input type="text" id="v-engine" name="vehicle_engine" placeholder="z.B. 2.0 TSI"
                    class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors">
                </div>
              </div>

              <!-- Fahrzeugschein-Upload (Pflicht) -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <label for="v-fahrzeugschein" class="block text-sm text-text-secondary">Fahrzeugschein *</label>
                  <button type="button" id="info-fahrzeugschein-btn" aria-label="Was wir genau brauchen"
                    class="w-4 h-4 rounded-full border border-text-muted text-text-muted hover:border-burnt hover:text-burnt transition-colors flex items-center justify-center text-[10px] font-semibold leading-none">i</button>
                </div>

                <label for="v-fahrzeugschein"
                  class="block w-full bg-bg-tertiary border-2 border-dashed border-border-strong hover:border-burnt cursor-pointer transition-colors px-4 py-6 text-center">
                  <svg class="w-6 h-6 mx-auto mb-2 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span id="v-fahrzeugschein-label" class="block text-sm text-text-primary font-medium">Foto vom Fahrzeugschein hochladen</span>
                  <span class="block text-xs text-text-muted mt-1">JPG, PNG oder PDF · max. 8 MB</span>
                  <input type="file" id="v-fahrzeugschein" name="fahrzeugschein"
                    accept="image/jpeg,image/png,image/heic,application/pdf"
                    required class="sr-only">
                </label>

                <!-- Erklärung -->
                <p class="mt-3 text-xs text-text-muted leading-relaxed">
                  Wir brauchen den Fahrzeugschein (Zulassungsbescheinigung Teil I, am liebsten die <span class="text-text-secondary">eingeklappte Seite mit den technischen Daten</span>), um einen so genauen Kostenvoranschlag wie möglich erstellen zu können — jedes Fahrzeug ist individuell. Wer sich unwohl fühlt, kann <span class="text-text-secondary">Name und Adresse vor dem Foto abdecken</span>.
                </p>

                <!-- Info-Popover (versteckt, JS toggelt) -->
                <div id="info-fahrzeugschein-box"
                  class="hidden mt-3 border border-burnt/40 bg-bg-tertiary p-4 rounded-sm">
                  <p class="text-xs text-text-primary font-medium mb-2">Was wir brauchen — und was nicht</p>
                  <ul class="text-xs text-text-secondary space-y-1 list-disc list-inside">
                    <li>Wichtig: die <span class="text-text-primary">eingeklappte Seite</span> mit Motor-Code, HSN/TSN, Hubraum, Leistung in kW</li>
                    <li>Foto scharf, alle Felder lesbar</li>
                    <li>Persönliche Daten (Name, Anschrift) können gerne überdeckt werden</li>
                    <li>Wir speichern den Schein nur für die Angebotserstellung und löschen ihn danach</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="mt-8 flex justify-end">
              <button type="button" class="btn-primary wizard-next" data-next="2">
                Weiter: Service wählen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </div>
          </div>

          <!-- STEP 2: Service -->
          <div class="wizard-step hidden" data-step="2">
            <h2 class="font-display text-2xl font-medium uppercase tracking-tight mb-6">Gewünschter Service</h2>

            <div class="space-y-3" id="service-options">
              <label class="flex items-center gap-4 p-4 border border-border-subtle bg-bg-tertiary cursor-pointer hover:border-burnt/30 transition-colors service-option">
                <input type="radio" name="service" value="Chiptuning / Kennfeldoptimierung" class="sr-only" required>
                <span class="w-5 h-5 rounded-full border-2 border-border-strong flex-shrink-0 flex items-center justify-center service-radio">
                  <span class="w-2.5 h-2.5 rounded-full bg-burnt scale-0 transition-transform"></span>
                </span>
                <div>
                  <p class="text-text-primary text-sm font-medium">Chiptuning / Kennfeldoptimierung</p>
                  <p class="text-text-muted text-xs mt-0.5">Stage 1, Stage 2 oder Individual</p>
                </div>
              </label>
              <label class="flex items-center gap-4 p-4 border border-border-subtle bg-bg-tertiary cursor-pointer hover:border-burnt/30 transition-colors service-option">
                <input type="radio" name="service" value="TÜV-Eintragung" class="sr-only">
                <span class="w-5 h-5 rounded-full border-2 border-border-strong flex-shrink-0 flex items-center justify-center service-radio">
                  <span class="w-2.5 h-2.5 rounded-full bg-burnt scale-0 transition-transform"></span>
                </span>
                <div>
                  <p class="text-text-primary text-sm font-medium">TÜV-Eintragung</p>
                  <p class="text-text-muted text-xs mt-0.5">Vorbereitung & Begleitung zum Sachverständigen-Termin</p>
                </div>
              </label>
              <label class="flex items-center gap-4 p-4 border border-border-subtle bg-bg-tertiary cursor-pointer hover:border-burnt/30 transition-colors service-option">
                <input type="radio" name="service" value="B2B-Prüftechnik" class="sr-only">
                <span class="w-5 h-5 rounded-full border-2 border-border-strong flex-shrink-0 flex items-center justify-center service-radio">
                  <span class="w-2.5 h-2.5 rounded-full bg-burnt scale-0 transition-transform"></span>
                </span>
                <div>
                  <p class="text-text-primary text-sm font-medium">B2B-Prüftechnik</p>
                  <p class="text-text-muted text-xs mt-0.5">Prüfstandsmessungen für Hersteller, Importeure & Tuning-Anbieter</p>
                </div>
              </label>
              <label class="flex items-center gap-4 p-4 border border-border-subtle bg-bg-tertiary cursor-pointer hover:border-burnt/30 transition-colors service-option">
                <input type="radio" name="service" value="Allgemeine Beratung" class="sr-only">
                <span class="w-5 h-5 rounded-full border-2 border-border-strong flex-shrink-0 flex items-center justify-center service-radio">
                  <span class="w-2.5 h-2.5 rounded-full bg-burnt scale-0 transition-transform"></span>
                </span>
                <div>
                  <p class="text-text-primary text-sm font-medium">Allgemeine Beratung</p>
                  <p class="text-text-muted text-xs mt-0.5">Ich bin mir noch nicht sicher</p>
                </div>
              </label>
            </div>

            <div class="mt-8 flex justify-between">
              <button type="button" class="btn-ghost wizard-prev" data-prev="1">Zurück</button>
              <button type="button" class="btn-primary wizard-next" data-next="3">
                Weiter: Ihre Daten
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </div>
          </div>

          <!-- STEP 3: Kontaktdaten -->
          <div class="wizard-step hidden" data-step="3">
            <h2 class="font-display text-2xl font-medium uppercase tracking-tight mb-6">Ihre Kontaktdaten</h2>

            <div class="space-y-5">
              <div>
                <label for="c-name" class="block text-sm text-text-secondary mb-2">Name *</label>
                <input type="text" id="c-name" name="name" required placeholder="Vor- und Nachname"
                  class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors">
              </div>
              <div>
                <label for="c-email" class="block text-sm text-text-secondary mb-2">E-Mail *</label>
                <input type="email" id="c-email" name="email" required placeholder="ihre@email.de"
                  class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors">
              </div>
              <div>
                <label for="c-phone" class="block text-sm text-text-secondary mb-2">Telefon <span class="text-text-muted">(optional)</span></label>
                <input type="tel" id="c-phone" name="phone" placeholder="+49 ..."
                  class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors">
              </div>
              <div>
                <label for="c-message" class="block text-sm text-text-secondary mb-2">Nachricht <span class="text-text-muted">(optional)</span></label>
                <textarea id="c-message" name="message" rows="4" placeholder="Was möchten Sie uns mitteilen?"
                  class="w-full bg-bg-tertiary border border-border-subtle text-text-primary px-4 py-3 text-sm placeholder:text-text-muted focus:outline-none focus:border-burnt transition-colors resize-y"></textarea>
              </div>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" id="c-privacy" name="privacy" required
                  class="mt-1 w-4 h-4 bg-bg-tertiary border-border-strong rounded-sm accent-burnt">
                <span class="text-text-secondary text-sm leading-relaxed">
                  Ich habe die <a href="/datenschutz" target="_blank" class="text-burnt hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu. *
                </span>
              </label>
            </div>

            <div class="mt-8 flex justify-between">
              <button type="button" class="btn-ghost wizard-prev" data-prev="2">Zurück</button>
              <button type="button" class="btn-primary wizard-next" data-next="4">
                Weiter: Zusammenfassung
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </div>
          </div>

          <!-- STEP 4: Zusammenfassung -->
          <div class="wizard-step hidden" data-step="4">
            <h2 class="font-display text-2xl font-medium uppercase tracking-tight mb-6">Zusammenfassung</h2>

            <div class="space-y-4">
              <div class="border border-border-subtle p-5 bg-bg-tertiary">
                <p class="label-caps text-burnt mb-3">Fahrzeug</p>
                <p class="text-text-primary" id="summary-vehicle">—</p>
              </div>
              <div class="border border-border-subtle p-5 bg-bg-tertiary">
                <p class="label-caps text-burnt mb-3">Service</p>
                <p class="text-text-primary" id="summary-service">—</p>
              </div>
              <div class="border border-border-subtle p-5 bg-bg-tertiary">
                <p class="label-caps text-burnt mb-3">Kontakt</p>
                <p class="text-text-primary" id="summary-name">—</p>
                <p class="text-text-secondary text-sm" id="summary-email">—</p>
                <p class="text-text-secondary text-sm" id="summary-phone"></p>
              </div>
              <div class="border border-border-subtle p-5 bg-bg-tertiary" id="summary-message-wrap" style="display:none">
                <p class="label-caps text-burnt mb-3">Nachricht</p>
                <p class="text-text-secondary text-sm" id="summary-message">—</p>
              </div>
            </div>

            <!-- Error display -->
            <div class="hidden mt-4 p-4 border border-error/30 bg-error/10 text-sm text-error" id="form-errors"></div>

            <div class="mt-8 flex justify-between">
              <button type="button" class="btn-ghost wizard-prev" data-prev="3">Zurück</button>
              <button type="submit" class="btn-primary" id="submit-btn">
                <span id="submit-text">Anfrage absenden</span>
                <svg class="w-4 h-4" id="submit-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                <svg class="w-4 h-4 animate-spin hidden" id="submit-spinner" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
              </button>
            </div>
          </div>

        </form>

        <!-- Success Message -->
        <div class="hidden" id="success-message">
          <div class="text-center py-16">
            <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-success/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-burnt-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
            <h2 class="font-display text-2xl font-medium uppercase tracking-tight mb-3">Anfrage gesendet</h2>
            <p class="text-text-secondary text-lg max-w-md mx-auto">
              Vielen Dank für Ihre Anfrage. Wir melden uns innerhalb von 24&nbsp;Stunden bei Ihnen.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/" class="btn-ghost">Zurück zur Startseite</a>
              <a href="tel:<%= phone %>" class="btn-primary">
                Direkt anrufen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-28 space-y-6">
          <!-- Contact Info -->
          <div class="border border-border-subtle p-6 bg-bg-tertiary">
            <p class="label-caps text-burnt mb-4">Direkter Kontakt</p>
            <div class="space-y-4">
              <a href="tel:<%= phone %>" class="flex items-center gap-3 text-text-primary hover:text-burnt transition-colors group">
                <svg class="w-5 h-5 text-text-muted group-hover:text-burnt transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                <span class="text-sm font-medium"><%= phone %></span>
              </a>
              <a href="mailto:<%= email %>" class="flex items-center gap-3 text-text-primary hover:text-burnt transition-colors group">
                <svg class="w-5 h-5 text-text-muted group-hover:text-burnt transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                <span class="text-sm font-medium"><%= email %></span>
              </a>
              <a href="https://wa.me/<%= phoneClean %>" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-primary hover:text-[#25D366] transition-colors group">
                <svg class="w-5 h-5 text-text-muted group-hover:text-[#25D366] transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span class="text-sm font-medium">WhatsApp schreiben</span>
              </a>
            </div>
          </div>

          <!-- Location -->
          <div class="border border-border-subtle p-6 bg-bg-tertiary">
            <p class="label-caps text-burnt mb-4">Standort</p>
            <address class="not-italic text-sm text-text-secondary space-y-1">
              <p class="text-text-primary font-medium">Vmax Sued</p>
              <p><%= address.street %></p>
              <p><%= address.access %></p>
              <p><%= address.zip %> <%= address.city %></p>
            </address>
            <div class="mt-4 pt-4 border-t border-border-subtle text-sm text-text-secondary space-y-1">
              <p><%= hours.weekdays %></p>
              <p><%= hours.saturday %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Wizard Script -->
<script>
(function() {
  var form = document.getElementById('contact-form');
  var steps = document.querySelectorAll('.wizard-step');
  var progressBar = document.getElementById('progress-bar');
  var stepCurrent = document.getElementById('step-current');
  var stepLabel = document.getElementById('step-label');
  var labels = { 1: 'Fahrzeug', 2: 'Service', 3: 'Kontaktdaten', 4: 'Zusammenfassung' };
  var currentStep = 1;

  function showStep(n) {
    steps.forEach(function(s) { s.classList.add('hidden'); });
    document.querySelector('[data-step="' + n + '"]').classList.remove('hidden');
    progressBar.style.width = (n * 25) + '%';
    stepCurrent.textContent = n;
    stepLabel.textContent = labels[n];
    currentStep = n;
    window.scrollTo({ top: 0, behavior: 'smooth' });

    if (n === 4) buildSummary();
  }

  // Fahrzeugschein: Info-Toggle + Datei-Label
  var infoBtn = document.getElementById('info-fahrzeugschein-btn');
  var infoBox = document.getElementById('info-fahrzeugschein-box');
  if (infoBtn && infoBox) {
    infoBtn.addEventListener('click', function() {
      infoBox.classList.toggle('hidden');
    });
  }
  var fzInput = document.getElementById('v-fahrzeugschein');
  var fzLabel = document.getElementById('v-fahrzeugschein-label');
  if (fzInput && fzLabel) {
    fzInput.addEventListener('change', function() {
      if (fzInput.files && fzInput.files[0]) {
        var f = fzInput.files[0];
        var kb = Math.round(f.size / 1024);
        fzLabel.textContent = '✓ ' + f.name + ' (' + kb + ' KB)';
        fzLabel.classList.add('text-success');
      } else {
        fzLabel.textContent = 'Foto vom Fahrzeugschein hochladen';
        fzLabel.classList.remove('text-success');
      }
    });
  }

  // Service radio visual feedback
  document.querySelectorAll('.service-option').forEach(function(opt) {
    var radio = opt.querySelector('input[type="radio"]');
    radio.addEventListener('change', function() {
      document.querySelectorAll('.service-option').forEach(function(o) {
        o.classList.remove('border-burnt/50');
        o.querySelector('.service-radio span').style.transform = 'scale(0)';
      });
      opt.classList.add('border-burnt/50');
      opt.querySelector('.service-radio span').style.transform = 'scale(1)';
    });
  });

  // Next buttons
  document.querySelectorAll('.wizard-next').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var next = parseInt(this.dataset.next);

      // Validate current step
      if (currentStep === 1) {
        if (!document.getElementById('v-brand').value) { highlight('v-brand'); return; }
        if (!document.getElementById('v-model').value.trim()) { highlight('v-model'); return; }
        var fz = document.getElementById('v-fahrzeugschein');
        if (!fz.files || !fz.files[0]) {
          highlight('v-fahrzeugschein');
          var lbl = document.querySelector('label[for="v-fahrzeugschein"]');
          if (lbl) { lbl.classList.add('border-error'); setTimeout(function(){ lbl.classList.remove('border-error'); }, 2000); }
          return;
        }
        if (fz.files[0].size > 8 * 1024 * 1024) {
          alert('Datei zu groß (max. 8 MB). Bitte komprimieren oder anderes Format wählen.');
          return;
        }
      }
      if (currentStep === 2) {
        var checked = document.querySelector('input[name="service"]:checked');
        if (!checked) {
          var container = document.getElementById('service-options');
          container.classList.add('ring-2', 'ring-error', 'ring-offset-2', 'ring-offset-bg-primary');
          container.scrollIntoView({ block: 'center', behavior: 'smooth' });
          setTimeout(function() {
            container.classList.remove('ring-2', 'ring-error', 'ring-offset-2', 'ring-offset-bg-primary');
          }, 2400);
          return;
        }
      }
      if (currentStep === 3) {
        if (!document.getElementById('c-name').value.trim()) { highlight('c-name'); return; }
        var emailVal = document.getElementById('c-email').value.trim();
        if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) { highlight('c-email'); return; }
        if (!document.getElementById('c-privacy').checked) { highlight('c-privacy'); return; }
      }

      showStep(next);
    });
  });

  // Prev buttons
  document.querySelectorAll('.wizard-prev').forEach(function(btn) {
    btn.addEventListener('click', function() {
      showStep(parseInt(this.dataset.prev));
    });
  });

  function highlight(id) {
    var el = document.getElementById(id);
    el.classList.add('border-error');
    el.focus();
    setTimeout(function() { el.classList.remove('border-error'); }, 2000);
  }

  function buildSummary() {
    var brand = document.getElementById('v-brand').value;
    var model = document.getElementById('v-model').value;
    var year = document.getElementById('v-year').value;
    var engine = document.getElementById('v-engine').value;
    var parts = [brand, model, year, engine].filter(Boolean);
    document.getElementById('summary-vehicle').textContent = parts.join(' · ');

    var service = document.querySelector('input[name="service"]:checked');
    document.getElementById('summary-service').textContent = service ? service.value : '—';

    document.getElementById('summary-name').textContent = document.getElementById('c-name').value;
    document.getElementById('summary-email').textContent = document.getElementById('c-email').value;
    var phone = document.getElementById('c-phone').value;
    document.getElementById('summary-phone').textContent = phone || '';

    var msg = document.getElementById('c-message').value.trim();
    if (msg) {
      document.getElementById('summary-message-wrap').style.display = '';
      document.getElementById('summary-message').textContent = msg;
    } else {
      document.getElementById('summary-message-wrap').style.display = 'none';
    }
  }

  // Submit
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = document.getElementById('submit-btn');
    var text = document.getElementById('submit-text');
    var arrow = document.getElementById('submit-arrow');
    var spinner = document.getElementById('submit-spinner');
    var errBox = document.getElementById('form-errors');

    btn.disabled = true;
    text.textContent = 'Wird gesendet...';
    arrow.classList.add('hidden');
    spinner.classList.remove('hidden');
    errBox.classList.add('hidden');

    var service = document.querySelector('input[name="service"]:checked');
    var fz = document.getElementById('v-fahrzeugschein');

    // FormData für Datei-Upload (multipart/form-data)
    var fd = new FormData();
    fd.append('vehicle_brand', document.getElementById('v-brand').value);
    fd.append('vehicle_model', document.getElementById('v-model').value);
    fd.append('vehicle_year', document.getElementById('v-year').value);
    fd.append('vehicle_engine', document.getElementById('v-engine').value);
    fd.append('service', service ? service.value : '');
    fd.append('name', document.getElementById('c-name').value.trim());
    fd.append('email', document.getElementById('c-email').value.trim());
    fd.append('phone', document.getElementById('c-phone').value.trim());
    fd.append('message', document.getElementById('c-message').value.trim());
    fd.append('privacy', document.getElementById('c-privacy').checked ? 'true' : 'false');
    if (fz.files && fz.files[0]) {
      fd.append('fahrzeugschein', fz.files[0]);
    }

    fetch('/api/contact', {
      method: 'POST',
      body: fd, // Browser setzt Content-Type incl. boundary automatisch
    })
    .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
    .then(function(result) {
      if (result.ok) {
        form.classList.add('hidden');
        document.querySelector('.mb-10').classList.add('hidden'); // progress bar
        document.getElementById('success-message').classList.remove('hidden');
      } else {
        var errors = result.data.errors || [result.data.error || 'Unbekannter Fehler'];
        errBox.innerHTML = errors.map(function(e) { return '<p>' + e + '</p>'; }).join('');
        errBox.classList.remove('hidden');
        btn.disabled = false;
        text.textContent = 'Anfrage absenden';
        arrow.classList.remove('hidden');
        spinner.classList.add('hidden');
      }
    })
    .catch(function() {
      errBox.innerHTML = '<p>Verbindungsfehler. Bitte versuchen Sie es erneut oder rufen Sie uns direkt an.</p>';
      errBox.classList.remove('hidden');
      btn.disabled = false;
      text.textContent = 'Anfrage absenden';
      arrow.classList.remove('hidden');
      spinner.classList.add('hidden');
    });
  });
})();
</script>

<%- include('../layouts/end') %>
